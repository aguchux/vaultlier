{
  "name": "@vaultlier/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./generated/client/client.ts",
      "default": "./generated/client/client.ts"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "build": "prisma generate",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@vaultlier/eslint-config": "*",
    "@vaultlier/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.7",
    "eslint": "^9.39.1",
    "prisma": "^7.8.0",
    "tsx": "^4.20.3",
    "typescript": "5.9.2"
  }
}
