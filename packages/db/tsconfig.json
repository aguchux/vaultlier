{
  "extends": "@vaultlier/typescript-config/base.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    // This package ships raw TS consumed by bundlers (Next) and tsx, so use
    // extensionless bundler resolution; NodeNext-style ".js" specifiers break
    // Turbopack's resolution of the generated client.
    "module": "Preserve",
    "moduleResolution": "Bundler"
  },
  "include": ["src", "prisma"],
  "exclude": ["node_modules", "generated"]
}
