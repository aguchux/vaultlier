# Postgres connection string used by Prisma. Copy to .env for local dev.
# Never commit a real connection string with credentials.

# Local Postgres:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vaultlier?schema=public"

# Hosted (e.g. Neon) — keep SSL params. node-postgres v8 deprecated bare
# `sslmode=require`; add `channel_binding=require` (Neon does this by default)
# or `uselibpqcompat=true` to silence the warning:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"
