{
  "name": "vaultlier",
  "version": "0.1.20",
  "description": "Typed runtime client, CLI, and type generation for the Vaultlier sealed configuration vault. Replaces the .env workflow without writing secret values to disk.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "vaultlier",
    "secrets",
    "env",
    "configuration",
    "vault",
    "dotenv",
    "cli",
    "runtime"
  ],
  "homepage": "https://vaultlier.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aguchux/vaultlier.git"
  },
  "bugs": {
    "url": "https://github.com/aguchux/vaultlier/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vaultlier": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:types",
    "build:js": "tsup",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "node -e \"for (const p of ['dist', '.turbo', 'coverage']) require('node:fs').rmSync(p, { recursive: true, force: true })\"",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "tsup": "^8.5.0",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.49.0",
    "vitest": "^3.2.6"
  }
}
